<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="co.edu.uniquindio.tallerbeta.controller.logincontroller"
           prefHeight="600" prefWidth="900"
           style="-fx-background-color: #080c14;">

   <!-- Fondo decorativo: paneles laterales -->
   <HBox>
      <!-- Panel izquierdo decorativo -->
      <VBox prefWidth="450" prefHeight="600" alignment="CENTER" spacing="0"
            style="-fx-background-color: #080c14; -fx-padding: 0 0 0 60;">

         <!-- Línea acento superior -->
         <Rectangle width="3" height="80"
                    style="-fx-fill: linear-gradient(to bottom, transparent, #e94560);"/>

         <VBox spacing="24" style="-fx-padding: 32 0 32 0;">
            <Text text="TALLER"
                  style="-fx-fill: #ffffff; -fx-font-size: 54;
                             -fx-font-weight: bold; -fx-font-family: 'Consolas';"/>
            <Text text="BETA"
                  style="-fx-fill: #e94560; -fx-font-size: 54;
                             -fx-font-weight: bold; -fx-font-family: 'Consolas';"/>
            <Text text="Sistema de Gestión&#10;de Órdenes de&#10;Mantenimiento"
                  style="-fx-fill: #4a5568; -fx-font-size: 15;
                             -fx-font-family: 'Consolas'; -fx-line-spacing: 6;"/>
         </VBox>

         <!-- Línea acento inferior -->
         <Rectangle width="3" height="80"
                    style="-fx-fill: linear-gradient(to bottom, #e94560, transparent);"/>

         <!-- Tags decorativos -->
         <VBox spacing="10" style="-fx-padding: 40 0 0 0;">
            <HBox spacing="10" alignment="CENTER_LEFT">
               <Rectangle width="8" height="8" arcWidth="8" arcHeight="8"
                          style="-fx-fill: #e94560;"/>
               <Text text="Registro de órdenes en tiempo real"
                     style="-fx-fill: #2d3748; -fx-font-size: 12; -fx-font-family: 'Consolas';"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
               <Rectangle width="8" height="8" arcWidth="8" arcHeight="8"
                          style="-fx-fill: #e94560;"/>
               <Text text="Seguimiento de estado por mecánico"
                     style="-fx-fill: #2d3748; -fx-font-size: 12; -fx-font-family: 'Consolas';"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
               <Rectangle width="8" height="8" arcWidth="8" arcHeight="8"
                          style="-fx-fill: #e94560;"/>
               <Text text="Panel de control para clientes"
                     style="-fx-fill: #2d3748; -fx-font-size: 12; -fx-font-family: 'Consolas';"/>
            </HBox>
         </VBox>
      </VBox>

      <!-- Panel derecho: formulario -->
      <VBox prefWidth="450" prefHeight="600" alignment="CENTER"
            style="-fx-background-color: #0d1117; -fx-padding: 0 60 0 60;">

         <VBox spacing="32" maxWidth="340">

            <!-- Encabezado -->
            <VBox spacing="6">
               <HBox spacing="10" alignment="CENTER_LEFT">
                  <Text text="⚙" style="-fx-font-size: 18; -fx-fill: #e94560;"/>
                  <Text text="Iniciar Sesión"
                        style="-fx-fill: #ffffff; -fx-font-size: 22;
                                     -fx-font-weight: bold; -fx-font-family: 'Consolas';"/>
               </HBox>
               <Text text="Accede a tu panel de órdenes"
                     style="-fx-fill: #4a5568; -fx-font-size: 12; -fx-font-family: 'Consolas';"/>
            </VBox>

            <!-- Campos -->
            <VBox spacing="18">
               <VBox spacing="7">
                  <HBox spacing="6" alignment="CENTER_LEFT">
                     <Text text="▸" style="-fx-fill: #e94560; -fx-font-size: 10;"/>
                     <Text text="CORREO ELECTRÓNICO"
                           style="-fx-fill: #718096; -fx-font-size: 10;
                                         -fx-font-family: 'Consolas'; -fx-font-weight: bold;"/>
                  </HBox>
                  <TextField fx:id="txtcorreo" promptText="usuario@correo.com"
                             style="-fx-background-color: #161b22;
                                          -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #2d3748;
                                          -fx-border-color: #21262d;
                                          -fx-border-width: 0 0 0 3;
                                          -fx-border-radius: 0; -fx-background-radius: 4;
                                          -fx-padding: 12 14 12 14;
                                          -fx-font-size: 13; -fx-font-family: 'Consolas';
                                          -fx-control-inner-background: #161b22;"/>
               </VBox>

               <VBox spacing="7">
                  <HBox spacing="6" alignment="CENTER_LEFT">
                     <Text text="▸" style="-fx-fill: #e94560; -fx-font-size: 10;"/>
                     <Text text="CONTRASEÑA"
                           style="-fx-fill: #718096; -fx-font-size: 10;
                                         -fx-font-family: 'Consolas'; -fx-font-weight: bold;"/>
                  </HBox>
                  <PasswordField fx:id="txtcontraseña" promptText="••••••••"
                                 style="-fx-background-color: #161b22;
                                              -fx-text-fill: #e2e8f0;
                                              -fx-prompt-text-fill: #2d3748;
                                              -fx-border-color: #21262d;
                                              -fx-border-width: 0 0 0 3;
                                              -fx-border-radius: 0; -fx-background-radius: 4;
                                              -fx-padding: 12 14 12 14;
                                              -fx-font-size: 13; -fx-font-family: 'Consolas';
                                              -fx-control-inner-background: #161b22;"/>
               </VBox>
            </VBox>

            <!-- Botón principal -->
            <VBox spacing="12">
               <Button fx:id="btniniciarsesion" text="INICIAR SESIÓN →"
                       onAction="#iniciarSesion" maxWidth="Infinity"
                       style="-fx-background-color: #e94560;
                                   -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-font-size: 13; -fx-font-family: 'Consolas';
                                   -fx-background-radius: 4; -fx-cursor: hand;
                                   -fx-padding: 14 0 14 0;
                                   -fx-effect: dropshadow(gaussian,rgba(233,69,96,0.5),16,0,0,4);"/>

               <Separator style="-fx-background-color: #21262d;"/>

               <HBox alignment="CENTER" spacing="8">
                  <Text text="¿Sin cuenta?"
                        style="-fx-fill: #4a5568; -fx-font-size: 12; -fx-font-family: 'Consolas';"/>
                  <Button fx:id="btnregistrarse" text="Regístrate aquí →"
                          onAction="#Registrarse"
                          style="-fx-background-color: transparent;
                                       -fx-text-fill: #e94560; -fx-font-size: 12;
                                       -fx-font-family: 'Consolas';
                                       -fx-cursor: hand; -fx-underline: true; -fx-padding: 0;"/>
               </HBox>
            </VBox>

         </VBox>
      </VBox>
   </HBox>

   <!-- Línea divisoria vertical central -->
   <Rectangle width="1" height="600"
              style="-fx-fill: linear-gradient(to bottom,
                      transparent 0%, #21262d 30%, #e94560 50%, #21262d 70%, transparent 100%);"/>

</StackPane>